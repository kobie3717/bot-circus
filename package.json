{
  "name": "bot-circus",
  "version": "1.0.0",
  "description": "Multi-bot Telegram orchestrator powered by Claude Code CLI",
  "type": "module",
  "bin": {
    "circus": "./bin/circus.js",
    "circus-lint": "./bin/circus-lint",
    "circus-migrate": "./bin/circus-migrate"
  },
  "main": "./lib/orchestrator.js",
  "scripts": {
    "start": "node lib/orchestrator.js",
    "dev": "node --watch lib/orchestrator.js",
    "test": "node --test --test-reporter=spec 'tests/contract/**/*.test.js' 'tests/integration/**/*.test.js'",
    "test:unit": "node --test --test-reporter=spec 'tests/contract/**/*.test.js'",
    "test:integration": "node --test --test-reporter=spec 'tests/integration/**/*.test.js'",
    "lint:contract": "node bin/circus-lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "commander": "^12.0.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.43.0",
    "gray-matter": "^4.0.3",
    "html-to-text": "^10.0.0",
    "imapflow": "^1.3.3",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^8.0.9",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "telegram",
    "bot",
    "orchestrator",
    "claude",
    "ai",
    "multi-bot"
  ],
  "author": "Kobie van Rooyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kobie3717/bot-circus"
  }
}
